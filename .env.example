# Core
LEARNABLE_ENV=development
LEARNABLE_LOG_LEVEL=INFO

# API
LEARNABLE_API_HOST=0.0.0.0
LEARNABLE_API_PORT=8000
LEARNABLE_API_URL=http://localhost:8000

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Storage
LEARNABLE_DATABASE_URL=postgresql+psycopg://learnable:learnable@localhost:5432/learnable
LEARNABLE_REDIS_URL=redis://localhost:6379/0
LEARNABLE_QDRANT_URL=http://localhost:6333
LEARNABLE_QDRANT_API_KEY=
LEARNABLE_MINIO_ENDPOINT=localhost:9000
LEARNABLE_MINIO_ACCESS_KEY=learnable
LEARNABLE_MINIO_SECRET_KEY=learnable123
LEARNABLE_MINIO_BUCKET=learnable
LEARNABLE_STORAGE_ROOT=./data

# Service mesh
LEARNABLE_INGEST_URL=http://localhost:8100
LEARNABLE_ORCHESTRATOR_URL=http://localhost:8200
LEARNABLE_MODEL_GATEWAY_URL=http://localhost:8300

# Local model serving
LEARNABLE_OLLAMA_URL=http://localhost:11434
LEARNABLE_MODEL_GATEWAY_MODE=mock
LEARNABLE_MODEL_GATEWAY_MOCK_FALLBACK=true
LEARNABLE_MODEL_PLANNER=qwen3:0.6b
LEARNABLE_MODEL_SYNTHESIZER=gemma3:1b
LEARNABLE_MODEL_SYNTHESIZER_FALLBACK=llama3.2:1b
LEARNABLE_MODEL_EMBEDDING=qwen3-embedding:0.6b
LEARNABLE_RERANKER_MODEL=bge-reranker-v2-m3

# Research budgets
LEARNABLE_MAX_RECURSION_DEPTH=3
LEARNABLE_MAX_SPAWNED_NODES=12
LEARNABLE_MAX_FETCHED_SOURCES=24
LEARNABLE_MAX_EVIDENCE_PER_NODE=8
LEARNABLE_MAX_TOKENS_PER_RUN=120000
LEARNABLE_MAX_RUNTIME_SECONDS=600
